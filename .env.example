# Copy this file to .env and fill in your values

# Required: Groq API key (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Required: PostgreSQL connection string
# For local dev: postgresql://postgres:password@localhost:5432/swing_analyzer
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Set to any random string (used to sign sessions)
SESSION_SECRET=change-me-to-a-random-secret

# Optional: Set REQUIRE_AUTH=true to enable login (default: guest auto-login)
# REQUIRE_AUTH=true
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your_password

# Node environment
NODE_ENV=development
